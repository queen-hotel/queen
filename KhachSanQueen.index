<div class="card">🧹 Dọn phòng hằng ngày</div>
<div class="card">🕒 Hỗ trợ 24/7</div>
</div>
</section>

<div class="contact">
<h2>LIÊN HỆ ĐẶT PHÒNG</h2>
<h1>0936 424 425</h1>
